  <property name="styleSheet">
   <string notr="true">/* Fenêtre principale */
QWidget {
    background-color: #F4F6F9;
    font-family: &quot;Segoe UI&quot;;
    font-size: 14px;
    color: #2D2D2D;
}

/* Panneau menu gauche */
#widget_menu {
    background-color: #1E293B;
    padding: 15px;
}

/* Titre menu */
#label_titre_menu {
    color: #000;
    font-size: 16px;
    font-weight: bold;
    padding: 20px 10px;
    border-bottom: 2px solid #FFFFFF;
}

/* Boutons menu */
#btn_dashboard, #btn_etudiants, #btn_enseignants,
#btn_matieres, #btn_seances, #btn_rapports {
    background-color: transparent;
    color: #CBD5E1;
    border: none;
    padding: 12px 15px;
    text-align: left;
    font-size: 14px;
    border-radius: 8px;
}

#btn_dashboard:hover, #btn_etudiants:hover, #btn_enseignants:hover,
#btn_matieres:hover, #btn_seances:hover, #btn_rapports:hover {
    background-color: #334155;
    color: #FFFFFF;
}

/* Bouton déconnexion */
#btn_deconnexion {
    background-color: transparent;
    color: #FFFFFF;
    border: 2px solid #FFFFFF;
    border-radius: 5px;
    padding: 10px;
    margin-top: 20px;
}

#btn_deconnexion:hover {
    background-color: #DC3545;
    border: 2px solid #DC3545;
}

/* Zone contenu */
#stackedWidget {
    background-color: #F5F5F5;
}

/* Tableau de bord - titre */
#label_bienvenue {
    color: #0096C7;
    font-size: 22px;
    font-weight: bold;
    padding: 20px;
}

/* Frames statistiques */
#frame_etudiants, #frame_enseignants,
#frame_matieres, #frame_seances {
    background-color: #FFFFFF;
    border-radius: 12px;
    padding: 15px;
    margin: 10px;
    border: none;
}

/* Nombres */
#label_nb_etudiants, #label_nb_enseignants,
#label_nb_matieres, #label_nb_seances {
    color: #0096C7;
    font-size: 36px;
    font-weight: bold;
}

/* Titres des frames */
#label_titre_etudiants, #label_titre_enseignants,
#label_titre_matieres, #label_titre_seances {
    color: #2D2D2D;
    font-size: 14px;
}

/* Titre de la page */
#label_titre_etudiants , #label_titre_enseignant, #label_titre_matiere, #label_titre_seance{
    color: #0096C7;
    font-size: 20px;
    font-weight: bold;
    padding: 10px;
}

/* Bouton Ajouter */
#btn_ajouter_etudiant, #btn_ajouter_enseignant, #btn_ajouter_matiere, #btn_ajouter_seance, #btn_actualiser {
    background-color: #0096C7;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
}

#btn_ajouter_etudiant:hover, #btn_ajouter_enseignant:hover, #btn_ajouter_matiere:hover, #btn_ajouter_seance:hover, #btn_actualiser:hover {
    background-color: #0077A8;
}

/* Bouton Modifier */
#btn_modifier_etudiant, #btn_modifier_enseignant, #btn_modifier_matiere, #btn_modifier_seance{
    background-color: #F0A500;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
}

#btn_modifier_etudiant:hover, #btn_modifier_enseignant:hover, #btn_modifier_matiere:hover, #btn_modifier_seance:hover {
    background-color: #C88400;
}

/* Bouton Supprimer */
#btn_supprimer_etudiant, #btn_supprimer_enseignant, #btn_supprimer_matiere , #btn_supprimer_seance{
    background-color: #DC3545;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
}

#btn_supprimer_etudiant:hover, #btn_supprimer_enseignant:hover, #btn_supprimer_matiere:hover , #btn_supprimer_seance:hover {
    background-color: #B02030;
}

/* Tableau */
QTableWidget {
    border: none;
    background-color: #FFFFFF;
    gridline-color: #E5E7EB;
    font-size: 13px;
    border-radius: 8px;
}

/* En-tête du tableau */
QHeaderView::section {
    background-color: #1E293B;
    color: #FFFFFF;
    padding: 10px;
    font-weight: bold;
    border: none;
}

QPushButton {
    border-radius: 8px;
}

QPushButton:pressed {
    background-color: #1D4ED8;
}

/* Lignes du tableau */
QTableWidget::item {
    padding: 5px;
    color: #2D2D2D;
}

/* Ligne sélectionnée */
QTableWidget::item:selected {
    background-color: #0096C7;
    color: #FFFFFF;
}

/* Lignes alternées */
QTableWidget::item:alternate {
    background-color: #F5F9FF;
}

/* Titre rapports */
#label_titre_rapports {
    color: #0096C7;
    font-size: 20px;
    font-weight: bold;
    padding: 10px;
}

/* TabWidget */
QTabWidget::pane {
    border: 2px solid #0096C7;
    border-radius: 5px;
    background-color: #FFFFFF;
}

QTabWidget::tab-bar {
    alignment: left;
}

QTabBar::tab {
    background-color: #F5F9FF;
    color: #0096C7;
    border: 2px solid #0096C7;
    border-bottom: none;
    border-radius: 5px 5px 0 0;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: bold;
    margin-right: 3px;
}

QTabBar::tab:selected {
    background-color: #0096C7;
    color: #FFFFFF;
}

QTabBar::tab:hover {
    background-color: #0077A8;
    color: #FFFFFF;
}


QScrollBar:vertical {
    border: none;
    background: #F1F1F1;
    width: 8px;
}

QScrollBar::handle:vertical {
    background: #0096C7;
    border-radius: 4px;
}

/* ComboBox rapports */
#comboBox_seances, #comboBox_etudiants, #comboBox_matieres {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px;
    font-size: 14px;
    color: #2D2D2D;
    background-color: #FFFFFF;
}

#comboBox_seances:focus, #comboBox_etudiants:focus, #comboBox_matieres:focus {
    border: 2px solid #0077A8;
}

#comboBox_seances::drop-down, #comboBox_etudiants::drop-down, #comboBox_matieres::drop-down {
    border: none;
    width: 30px;
}

#comboBox_seances QAbstractItemView,
#comboBox_etudiants QAbstractItemView,
#comboBox_matieres QAbstractItemView {
    border: 2px solid #0096C7;
    background-color: #FFFFFF;
    selection-background-color: #0096C7;
    selection-color: #FFFFFF;
}

/* Labels info */
#label_info_seance, #label_info_etudiant, #label_info_matiere {
    color: #0096C7;
    font-size: 14px;
    font-weight: bold;
    padding: 8px 10px;
    border: 2px solid #E0E0E0;
    border-radius: 5px;
    background-color: #F5F9FF;
}

/* Labels stats */
#label_stats_seance, #label_stats_etudiant, #label_stats_matiere {
    color: #2D2D2D;
    font-size: 14px;
    font-weight: bold;
    padding: 8px 10px;
    background-color: #F5F9FF;
    border-radius: 5px;
    border: 2px solid #E0E0E0;
}</string>
