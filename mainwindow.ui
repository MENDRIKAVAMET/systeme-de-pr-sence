  <property name="styleSheet">
   <string notr="true">/* Fenêtre principale */
QWidget {
    background-color: #FFFFFF;
    font-family: Arial;
    font-size: 14px;
}

/* Panneau menu gauche */
#widget_menu {
    background-color: #0077A8;
    padding: 10px;
}

/* Titre menu */
#label_titre_menu {
    color: #000;
    font-size: 16px;
    font-weight: bold;
    padding: 20px 10px;
    border-bottom: 2px solid #FFFFFF;
}

/* Boutons menu */
#btn_dashboard, #btn_etudiants, #btn_enseignants,
#btn_matieres, #btn_seances, #btn_rapports {
    background-color: transparent;
    color: #FFFFFF;
    border: none;
    padding: 12px 10px;
    text-align: left;
    font-size: 14px;
}

#btn_dashboard:hover, #btn_etudiants:hover, #btn_enseignants:hover,
#btn_matieres:hover, #btn_seances:hover, #btn_rapports:hover {
    background-color: #0096C7;
    border-radius: 5px;
}

/* Bouton déconnexion */
#btn_deconnexion {
    background-color: transparent;
    color: #FFFFFF;
    border: 2px solid #FFFFFF;
    border-radius: 5px;
    padding: 10px;
    margin-top: 20px;
}

#btn_deconnexion:hover {
    background-color: #DC3545;
    border: 2px solid #DC3545;
}

/* Zone contenu */
#stackedWidget {
    background-color: #F5F5F5;
}

/* Tableau de bord - titre */
#label_bienvenue {
    color: #0096C7;
    font-size: 22px;
    font-weight: bold;
    padding: 20px;
}

/* Frames statistiques */
#frame_etudiants, #frame_enseignants,
#frame_matieres, #frame_seances {
    background-color: #FFFFFF;
    border: 2px solid #0096C7;
    border-radius: 10px;
    padding: 10px;
    margin: 10px;
}

/* Nombres */
#label_nb_etudiants, #label_nb_enseignants,
#label_nb_matieres, #label_nb_seances {
    color: #0096C7;
    font-size: 36px;
    font-weight: bold;
}

/* Titres des frames */
#label_titre_etudiants, #label_titre_enseignants,
#label_titre_matieres, #label_titre_seances {
    color: #2D2D2D;
    font-size: 14px;
}

/* Titre de la page */
#label_titre_etudiants , #label_titre_enseignant, #label_titre_matiere, #label_titre_seance{
    color: #0096C7;
    font-size: 20px;
    font-weight: bold;
    padding: 10px;
}

/* Bouton Ajouter */
#btn_ajouter_etudiant, #btn_ajouter_enseignant, #btn_ajouter_matiere, #btn_ajouter_seance {
    background-color: #0096C7;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
}

#btn_ajouter_etudiant:hover, #btn_ajouter_enseignant:hover, #btn_ajouter_matiere:hover, #btn_ajouter_seance:hover {
    background-color: #0077A8;
}

/* Bouton Modifier */
#btn_modifier_etudiant, #btn_modifier_enseignant, #btn_modifier_matiere, #btn_modifier_seance{
    background-color: #F0A500;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
}

#btn_modifier_etudiant:hover, #btn_modifier_enseignant:hover, #btn_modifier_matiere:hover, #btn_modifier_seance:hover {
    background-color: #C88400;
}

/* Bouton Supprimer */
#btn_supprimer_etudiant, #btn_supprimer_enseignant, #btn_supprimer_matiere , #btn_supprimer_seance{
    background-color: #DC3545;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
}

#btn_supprimer_etudiant:hover, #btn_supprimer_enseignant:hover, #btn_supprimer_matiere:hover , #btn_supprimer_seance:hover {
    background-color: #B02030;
}

/* Tableau */
QTableWidget {
    border: 1px solid #E0E0E0;
    background-color: #FFFFFF;
    gridline-color: #E0E0E0;
    font-size: 13px;
}

/* En-tête du tableau */
QHeaderView::section {
    background-color: #0096C7;
    color: #FFFFFF;
    padding: 8px;
    font-size: 13px;
    font-weight: bold;
    border: none;
}

/* Lignes du tableau */
QTableWidget::item {
    padding: 5px;
    color: #2D2D2D;
}

/* Ligne sélectionnée */
QTableWidget::item:selected {
    background-color: #0096C7;
    color: #FFFFFF;
}

/* Lignes alternées */
QTableWidget::item:alternate {
    background-color: #F5F9FF;
}</string>
