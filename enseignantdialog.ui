  <property name="styleSheet">
   <string notr="true">/* Fenêtre dialog */
QDialog {
    background-color: #FFFFFF;
    font-family: Arial;
    font-size: 14px;
}

/* Titre */
#label_titre {
    color: #0096C7;
    font-size: 18px;
    font-weight: bold;
    padding: 10px;
}

/* Labels */
#label_nom, #label_prenoms, #label_email, #label_telephone {
    color: #2D2D2D;
    font-weight: bold;
    margin-top: 5px;
}

/* Champs de saisie */
QLineEdit {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px;
    font-size: 14px;
    color: #2D2D2D;
}

QLineEdit:focus {
    border: 2px solid #0077A8;
    background-color: #F0F9FF;
}

/* Bouton enregistrer */
#btn_enregistrer {
    background-color: #0096C7;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: bold;
}

#btn_enregistrer:hover {
    background-color: #0077A8;
}

/* Bouton annuler */
#btn_annuler {
    background-color: #FFFFFF;
    color: #DC3545;
    border: 2px solid #DC3545;
    border-radius: 5px;
    padding: 10px 20px;
    font-size: 14px;
}

#btn_annuler:hover {
    background-color: #DC3545;
    color: #FFFFFF;
}</string>
