  <property name="styleSheet">
   <string notr="true">/* Fenêtre principale */
QWidget {
    background-color: #FFFFFF;
    font-family: Arial;
    font-size: 14px;
}

/* Barre titre */
#widget_header {
    background-color: #0096C7;
    padding: 10px;
}

#label_nom_enseignant {
    color: #FFFFFF;
    font-size: 18px;
    font-weight: bold;
	background-color: transparent;
}

/* Bouton déconnexion */
#btn_deconnexion {
    background-color: transparent;
    color: #FFFFFF;
    border: 2px solid #FFFFFF;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 14px;
}

#btn_deconnexion:hover {
    background-color: #DC3545;
    border: 2px solid #DC3545;
}

/* Titre page */
#label_titre_seances_jour {
    color: #0096C7;
    font-size: 20px;
    font-weight: bold;
    padding: 10px;
}

/* Tableau */
QTableWidget {
    border: 1px solid #E0E0E0;
    background-color: #FFFFFF;
    gridline-color: #E0E0E0;
    font-size: 13px;
}

QHeaderView::section {
    background-color: #0096C7;
    color: #FFFFFF;
    padding: 8px;
    font-size: 13px;
    font-weight: bold;
    border: none;
}

QTableWidget::item {
    padding: 5px;
    color: #2D2D2D;
}

QTableWidget::item:selected {
    background-color: #0096C7;
    color: #FFFFFF;
}

QTableWidget::item:alternate {
    background-color: #F5F9FF;
}

/* Bouton démarrer */
#btn_demarrer_presence {
    background-color: #28A745;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 10px 20px;
    font-size: 15px;
    font-weight: bold;
}

#btn_demarrer_presence:hover {
    background-color: #218838;
}

/* Page séance en cours */
#label_info_seance {
    color: #0096C7;
    font-size: 18px;
    font-weight: bold;
    padding: 10px;
}

#label_statut {
    color: #2D2D2D;
    font-size: 16px;
    padding: 10px;
    border: 2px solid #E0E0E0;
    border-radius: 5px;
}

#label_nom_etudiant {
    font-size: 22px;
    font-weight: bold;
    padding: 15px;
    border-radius: 10px;
}

/* Bouton terminer */
#btn_terminer {
    background-color: #DC3545;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 10px 20px;
    font-size: 15px;
    font-weight: bold;
}

#btn_terminer:hover {
    background-color: #B02030;
}

/* Bouton historique */
#btn_historique {
    background-color: #0096C7;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
    border: none;
}

#btn_historique:hover {
    background-color: #0077A8;
}

/* Titre historique */
#label_titre_historique {
    color: #0096C7;
    font-size: 20px;
    font-weight: bold;
    padding: 10px;
}

/* Bouton retour */
#btn_retour_historique {
    background-color: transparent;
    color: #0096C7;
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
}

#btn_retour_historique:hover {
    background-color: #0096C7;
    color: #FFFFFF;
}

/* ComboBox séances */
#comboBox_seances_hist {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px;
    font-size: 14px;
    color: #2D2D2D;
    background-color: #FFFFFF;
}

#comboBox_seances_hist:focus {
    border: 2px solid #0077A8;
}

#comboBox_seances_hist::drop-down {
    border: none;
    width: 30px;
}

#comboBox_seances_hist QAbstractItemView {
    border: 2px solid #0096C7;
    border-radius: 5px;
    background-color: #FFFFFF;
    selection-background-color: #0096C7;
    selection-color: #FFFFFF;
}

/* Info séance */
#label_info_hist {
    color: #0096C7;
    font-size: 14px;
    font-weight: bold;
    padding: 5px 10px;
    border: 2px solid #E0E0E0;
    border-radius: 5px;
    background-color: #F5F9FF;
}

/* Stats */
#label_stats_hist {
    color: #2D2D2D;
    font-size: 14px;
    font-weight: bold;
    padding: 8px 10px;
    background-color: #F5F9FF;
    border-radius: 5px;
    border: 2px solid #E0E0E0;
}</string>
