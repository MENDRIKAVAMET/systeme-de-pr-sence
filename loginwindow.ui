  <property name="styleSheet">
   <string notr="true">/* Fenêtre principale */
QWidget {
    background-color: #FFFFFF;
    font-family: Arial;
    font-size: 14px;
}

/* Titre */
#label_titre {
    color: #0096C7;
    font-size: 22px;
    font-weight: bold;
    padding: 20px;
}

/* Labels */
#label_login, #label_password {
    color: #2D2D2D;
    font-weight: bold;
    margin-top: 10px;
}

/* Champs de saisie */
QLineEdit {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px;
    font-size: 14px;
    color: #2D2D2D;
}

QLineEdit:focus {
    border: 2px solid #0077A8;
    background-color: #F0F9FF;
}

/* Bouton connexion */
#btn_connexion {
    background-color: #0096C7;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 10px;
    font-size: 15px;
    font-weight: bold;
}

#btn_connexion:hover {
    background-color: #0077A8;
}

#btn_connexion:pressed {
    background-color: #005F8A;
}

/* Label erreur */
#label_erreur {
    color: #DC3545;
    font-size: 13px;
}</string>
