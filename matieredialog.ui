  <property name="styleSheet">
   <string notr="true">/* Fenêtre dialog */
QDialog {
    background-color: #FFFFFF;
    font-family: Arial;
    font-size: 14px;
}

/* Titre */
#label_titre{
    color: #0096C7;
    font-size: 18px;
    font-weight: bold;
    padding: 10px;
}

/* Labels */
#label_code, #label_nom, #label_volume, #label_classe {
    color: #2D2D2D;
    font-weight: bold;
    margin-top: 5px;
}

/* Champs de saisie */
QLineEdit {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px;
    font-size: 14px;
    color: #2D2D2D;
}

QLineEdit:focus {
    border: 2px solid #0077A8;
    background-color: #F0F9FF;
}

/* ComboBox */
QComboBox {
    border: 2px solid #0096C7;
    padding: 8px;
	 border-radius: 8px;
    font-size: 14px;
    color: #2D2D2D;
    background-color: #FFFFFF;
}

QComboBox:focus {
    border: 2px solid #0077A8;
}

QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    border: 2px solid #0096C7;
    border-radius: 5px;
    background-color: #FFFFFF;
    selection-background-color: #0096C7;
    selection-color: #FFFFFF;
}

/* Bouton enregistrer */
#btn_enregistrer {
    background-color: #0096C7;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: bold;
}

#btn_enregistrer:hover {
    background-color: #0077A8;
}

/* Bouton annuler */
#btn_annuler {
    background-color: #FFFFFF;
    color: #DC3545;
    border: 2px solid #DC3545;
    border-radius: 5px;
    padding: 10px 20px;
    font-size: 14px;
}

#btn_annuler:hover {
    background-color: #DC3545;
    color: #FFFFFF;
}

/* GroupBox */
QGroupBox {
    margin-top: 10px;
    font-weight: bold;
    color: #0096C7;
    padding: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 5px;
 	color: #2D2D2D;
}

/* ListWidget */
QListWidget {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 5px;
    background-color: #FFFFFF;
    font-size: 13px;
    color: #2D2D2D;
}

QListWidget::item {
    padding: 5px;
    border-radius: 3px;
}

QListWidget::item:hover {
    background-color: #F0F9FF;
}

QListWidget::item:selected {
    background-color: #0096C7;
    color: #FFFFFF;
}

/* Case à cocher dans ListWidget */
QListWidget::indicator {
    width: 15px;
    height: 15px;
}

QListWidget::indicator:unchecked {
    border: 2px solid #0096C7;
    border-radius: 3px;
    background-color: #FFFFFF;
}

QListWidget::indicator:checked {
    border: 2px solid #0096C7;
    border-radius: 3px;
    background-color: #0096C7;
}</string>
  </property>
