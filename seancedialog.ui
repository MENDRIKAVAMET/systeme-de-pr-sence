  <property name="styleSheet">
   <string notr="true">/* Fenêtre dialog */
QDialog {
    background-color: #FFFFFF;
    font-family: Arial;
    font-size: 14px;
}

/* Titre */
#label_titre {
    color: #0096C7;
    font-size: 18px;
    font-weight: bold;
    padding: 10px;
}

/* Labels */
#label_matiere, #label_classe, #label_date,
#label_heure_debut, #label_heure_fin {
    color: #2D2D2D;
    font-weight: bold;
    margin-top: 5px;
}

/* Champs de saisie */
QLineEdit {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px;
    font-size: 14px;
    color: #2D2D2D;
}

QLineEdit:focus {
    border: 2px solid #0077A8;
    background-color: #F0F9FF;
}

/* ComboBox */
QComboBox {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px;
    font-size: 14px;
    color: #2D2D2D;
    background-color: #FFFFFF;
}

QComboBox:focus {
    border: 2px solid #0077A8;
}

QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox QAbstractItemView {
    border: 2px solid #0096C7;
    border-radius: 5px;
    background-color: #FFFFFF;
    selection-background-color: #0096C7;
    selection-color: #FFFFFF;
}

/* DateEdit */
QDateEdit {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px;
    font-size: 14px;
    color: #2D2D2D;
    background-color: #FFFFFF;
}

QDateEdit:focus {
    border: 2px solid #0077A8;
    background-color: #F0F9FF;
}

QDateEdit::drop-down {
    border: none;
    width: 30px;
}

/* TimeEdit */
QTimeEdit {
    border: 2px solid #0096C7;
    border-radius: 5px;
    padding: 8px;
    font-size: 14px;
    color: #2D2D2D;
    background-color: #FFFFFF;
}

QTimeEdit:focus {
    border: 2px solid #0077A8;
    background-color: #F0F9FF;
}

QTimeEdit::drop-down {
    border: none;
    width: 30px;
}

/* Bouton enregistrer */
#btn_enregistrer {
    background-color: #0096C7;
    color: #FFFFFF;
    border-radius: 5px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: bold;
}

#btn_enregistrer:hover {
    background-color: #0077A8;
}

/* Bouton annuler */
#btn_annuler {
    background-color: #FFFFFF;
    color: #DC3545;
    border: 2px solid #DC3545;
    border-radius: 5px;
    padding: 10px 20px;
    font-size: 14px;
}

#btn_annuler:hover {
    background-color: #DC3545;
    color: #FFFFFF;
}</string>
